  "license": "ISC",
  "description": "Network node application with command-driven architecture",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "better-sqlite3": "^11.6.0",
    "canonicalize": "^2.0.0",
    "hono": "^4.6.12",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
