# syntax=docker/dockerfile:1
#
# Development image for vouch-node with hot reload. Mount ./vouch-node/src over
# /app/vouch-node/src (see docker-compose.yml, `dev` profile) and Bun re-runs on change.

FROM oven/bun:1.3.2-alpine
WORKDIR /app

COPY vouch-core ./vouch-core
COPY vouch-world ./vouch-world
COPY vouch-node ./vouch-node

WORKDIR /app/vouch-node
RUN bun install

RUN mkdir -p /app/data
ENV VOUCH_HOST=0.0.0.0 \
    VOUCH_PORT=8787 \
    VOUCH_JOURNAL=/app/data/journal.jsonl \
    VOUCH_ACCOUNTS=/app/data/accounts.jsonl

EXPOSE 8787
CMD ["bun", "--watch", "src/index.ts"]
