# Dependencies (root + every package — nested must be excluded so the image installs fresh)
**/node_modules

# Build output
**/dist

# Database / journal data
*.db
*.db-wal
*.db-shm
**/data/

# Environment files
.env
.env.local
.env.*.local

# Test files (not needed at runtime)
**/*.test.ts
**/test/
**/coverage/
**/examples/

# Development files
.git/
.gitignore
*.md
docs/
.mcp.json

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore
